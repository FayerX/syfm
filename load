function GoPath(t, s, v, x, y) 
    if GetWorld() == nil then 
        return 
    end 
    SendPacketRaw(false, {
        type = t, 
        state = s, 
        value = v, 
        px = x, 
        py = y, 
        x = x * 32, 
        y = y * 32
    }) 
    if t == nil then 
         SendVariantList({[0] = "OnSetPos",[1] = {x = x*32, y = y*32}}, GetLocal().netid)
    end 
end

function tele(x, y) 
    if GetWorld() == nil or GetLocal() == nil then
        return
    end
    iX, iY = math.floor(GetLocal().pos.x / 32), math.floor(GetLocal().pos.y / 32) 
    DistX = x - iX 
    DistY = y - iY 
    if DistY > 1 then 
        for i = 1, math.floor(DistY / 1) do 
            iY = iY + 1 
            GoPath(3, 1, 0, iX, iY) 
            GoPath(nil, nil, nil, iX, iY) 
        end 
    elseif DistY < -1 then 
        for i = 1, math.floor(DistY / -1) do 
            iY = iY - 1 
            GoPath(3, 1, 0, iX, iY) 
            GoPath(nil, nil, nil, iX, iY) 
        end 
    end 
    if DistX > 1 then 
        for i = 1, math.floor(DistX / 1) do 
            iX = iX + 1 
            GoPath(3, 1, 0, iX, iY) 
            GoPath(nil, nil, nil, iX, iY) 
        end 
    elseif DistX < -1 then 
        for i = 1, math.floor(DistX / -1) do 
            iX = iX - 1 
            GoPath(3, 1, 0, iX, iY) 
            GoPath(nil, nil, nil, iX, iY) 
        end 
    end 
    iX, iY = x, y 
    GoPath(3, 1, 0, iX, iY) 
    GoPath(nil, nil, nil, iX, iY)  
end

function inv(itemid)
    for _, item in pairs(GetInventory()) do
        if item.id == itemid then return item.amount end
    end
    return 0
end

function isWorldSafe()
    local players = GetPlayerList()
    if not players then return true end

    local myID = GetLocal().userid

    for _, p in pairs(players) do
        if p.userid ~= myID then
            if not isWhitelisted(p.userid, p.name) then
                return false
            end
        end
    end

    return true
end

function hasStaffOnline()
    return next(staffOnline) ~= nil
end

function shouldPause()
    if safetyMode ~= "pause" then
        return false
    end

    if hasStaffOnline() then
        return true
    end

    if not isWorldSafe() then
        return true
    end

    return false
end

function isWhitelisted(userID, name)
    -- userID
    for _, id in pairs(whitelistUsers) do
        if id == userID then
            return true
        end
    end
	-- Nama
    local clean = cleanName(name)
    for _, n in pairs(whitelistNames) do
        if n == clean then
            return true
        end
    end

    return false
end

function notify(msg, color)
    SendVariantList({
        [0] = "OnAddNotification",
        [1] = "interface/atomic_button.rttex",
        [2] = color..msg,
        [3] = "audio/hub_open.wav",
        [4] = 0
    })
end

function randomResumeDelay()
    return math.random(resumeDelayMin, resumeDelayMax)
end

function placeSeed(x, y)
    local pkt = {
        type = 3,
        px = x,
        py = y,
        x = x * 32,
        y = y * 32,
        value = seedid
    }
    SendPacketRaw(false, pkt)
end

function breakBlock(x, y)
    local brek = {
        type = 3,
        px = x,
        py = y,
        x = x * 32,
        y = y * 32,
        value = 18
    }
    SendPacketRaw(false, brek)
end

function breakMe(id)
  SendPacketRaw(false, {
    type  = 3,
    value = id,
    px    = GetLocal().pos.x // 32,
    py    = GetLocal().pos.y // 32,
    x     = GetLocal().pos.x // 32 * 32,
    y     = GetLocal().pos.y // 32 * 32
  })
end

function isBreakTarget(id)
    for _, v in pairs(breakIDs) do
        if v == id then
            return true
        end
    end
    return false
end

function break_tile(x, y)
    SendPacketRaw(false, {
        state = 32,
        x = x * 32-1,
        y = y * 32
    })
    SendPacketRaw(false, {
        type = 3,
        value = 18,
        px = x,
        py = y,
        x = x * 32,
        y = y * 32
    })
end

function fastPlant()
    for x = farmStartX, farmEndX do
		if safetyMode == "pause" and shouldPause() then
			return
		end

        local tile = GetTile(x, farmY)
        if tile and tile.fg == 0 then
            local below = GetTile(x, farmY + 1)
            if below and below.fg ~= 0 then
                if inv(seedid) > 0 then
                    placeSeed(x, farmY)
                else
                    return
                end
            end
        end
    end
end

function fastBrek()
    for x = farmStartX, farmEndX do
		if safetyMode == "pause" and shouldPause() then
			return
		end

        local tile = GetTile(x, farmY)
        if tile and isBreakTarget(tile.fg) then
            local below = GetTile(x, farmY + 1)
            if below and below.fg ~= 0 then
--				breakBlock(brikX, brikY)
				break_tile(x, farmY)		
				Sleep(delay)
            end
        end
    end
end

function Wrench(x, y)
SendPacketRaw(false, {
  ["type"] = 3,
  ["state"] = 32,
  ["value"] = 32,
  ["px"] = x,
  ["py"] = y,
  ["x"] = x * 32,
  ["y"] = y * 32
})
end

function checkWorld()
    local world = GetWorld()
    
    if world == nil then
        if worldReady then
            print("World left. Waiting...")
            worldReady = false
        end
        return false
    end

    if world.name ~= currentWorld then
        currentWorld = world.name
        worldReady = true
        print("Entered world:", currentWorld)
		Sleep(1500) -- tunggu entity load
		FindPath(0,114)
		allMagEmpty = false
		needSwitch = false
		currentMag = 1
		emptyCount = 0
		cycleChecked = false
		checkedMag = {}
        Sleep(1500)
        scanMagplants()
    end

    return true
end

function cleanName(str)
    return str:gsub("`.", "")
end

