function main()
	while GetWorld() == nil do
		Sleep(3000)
	end

--	Sleep(500)
--	scanMagplants()
--	Sleep(3000)
    while true do

        if not checkWorld() then
            Sleep(500)
            goto continue
        end

        if #magplants == 0 then
            print("No magplants found.")
            break
        end

        -- =====================================
        -- PRIORITAS 1: SAFETY MODE
        -- =====================================

		if safetyMode == "pause" then
			if shouldPause() then
				lastUnsafe = os.time()
				waitingResume = true
				Sleep(1000)
				goto continue
			end

			-- kalau sebelumnya unsafe dan sekarang aman
			if waitingResume then
				local waitTime = randomResumeDelay()
				print("`2World clear. Waiting "..waitTime.." sec before resume.")
				notify("No staff detected. Script resumed.", "`2")
				LogToConsole("`2No staff detected. Script resumed.")
				Sleep(waitTime * 1000)
				waitingResume = false
				detected = false
--				tele(0,114)
				FindPath(0,114)
			end
		end

        -- =====================================
        -- PRIORITAS 2: SWITCH MAGPLANT
        -- =====================================

		if needSwitch then
			needSwitch = false
			switchMagplant()
		end

		if cycleChecked then
			if emptyCount >= #magplants then
				print("Semua magplant benar-benar kosong. STOP.")
				break
			else
				print("Refill detected. Reset cycle.")
				scanMagplants()
				cycleChecked = false
			end
		end

        -- =====================================
        -- PRIORITAS 3: FARMING
        -- =====================================

		if inv(seedid) > 0 then
			fastPlant()
			fastBrek()
		else
			if os.time() - lastSwitch > switchDelay then
				print("Seed kosong, cek magplant...")
				Wrench(activeMagX, activeMagY)
				lastSwitch = os.time()
			end
			Sleep(500)
		end

        ::continue::
        Sleep(100)
    end
end

