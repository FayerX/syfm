AddHook("OnVariant", "MagplantStockReader", function(var)

    if var[0] ~= "OnDialogRequest" then return end
    if not var[1] then return end

    -- ambil tile
    local tilex = tonumber(var[1]:match("tilex|(%d+)"))
    local tiley = tonumber(var[1]:match("tiley|(%d+)"))

    if tilex ~= activeMagX or tiley ~= activeMagY then return end

    -- prevent spam read
	if os.time() - lastDialogRead < dialogDelay then return end
	lastDialogRead = os.time()

    -- cek stock
    local stock = var[1]:match("The machine contains (%d+)")
    if stock then
        stock = tonumber(stock)
        print("Magplant index "..currentMag.." stock:", stock)

        if stock == 0 and not checkedMag[currentMag] then
            checkedMag[currentMag] = true
            emptyCount = emptyCount + 1
            print("Empty confirmed at index:", currentMag)
            requestSwitch()
        end
    end

    -- fallback
    if var[1]:find("The machine is currently empty!") then
        if not checkedMag[currentMag] then
            checkedMag[currentMag] = true
            emptyCount = emptyCount + 1
            print("Dialog empty fallback at index:", currentMag)
            requestSwitch()
        end
    end

end)

AddHook("OnVariant", "EmptyBubble", function(var)
    if var[0] ~= "OnTalkBubble" then return end
    if not var[2] then return end

    if not var[2]:find("Magplant") then return end
    if not var[2]:find("empty") then return end

    if os.time() - lastBubble < bubbleDelay then return end
    lastBubble = os.time()

    requestSwitch()
    return true
end)

