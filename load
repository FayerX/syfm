function scanMagplants()
    magplants = {}
    currentMag = 0
    checkedMag = {}
    emptyCount = 0
    cycleChecked = false

    for _, tile in pairs(GetTiles()) do
        if tile.bg == BackgroundMag and 
           (tile.fg == 5638 or tile.fg == 9850 or tile.fg == 10266) then
            table.insert(magplants, {x = tile.x, y = tile.y})
        end
    end

    table.sort(magplants, function(a,b)
        return a.x < b.x
    end)

    print("Found "..#magplants.." magplants.")

    if #magplants > 0 then
        currentMag = 1
        activeMagX = magplants[1].x
        activeMagY = magplants[1].y
        print("Setting initial magplant...")
        Wrench(activeMagX, activeMagY)
        lastSwitch = os.time()
    end
end
function switchMagplant()

    if #magplants == 0 then return end
    if os.time() - lastSwitch < switchDelay then return end

    if currentMag >= #magplants then
        cycleChecked = true
        return
    end

    currentMag = currentMag + 1

    activeMagX = magplants[currentMag].x
    activeMagY = magplants[currentMag].y
    lastSwitch = os.time()

    print("Switching to magplant "..currentMag)
    Wrench(activeMagX, activeMagY)
end
function requestSwitch()
    if os.time() - lastSwitch < switchDelay then return end
    if needSwitch then return end
    needSwitch = true
end
