AddHook("OnVariant", "STAFF_DETECT", function(var)
    if var[0] ~= "OnSpawn" or not var[1] then return end

    local data = var[1]
    local userID  = tonumber(data:match("userID|(%d+)"))
    local netID   = tonumber(data:match("netID|(%d+)"))
    local name    = data:match("name|(.-)\n") or "Unknown"
    local invis   = data:match("invis|(%d)")
    local mstate  = data:match("mstate|(%d)")
    local smstate = data:match("smstate|(%d)")
    local isMod   = data:find("mod|1")

	local localPlayer = GetLocal()
	if not userID then return end
	if not localPlayer then return end
	if userID == localPlayer.userid then return end
	if isWhitelisted(userID, name) then return end

    local detected = false

    -- Deteksi eksplisit mod
    if isMod then
        detected = true
    end

    -- Deteksi invis / special state (opsional keras)
    if invis == "1" or mstate == "1" or smstate == "1" then
        detected = true
    end

    if detected then
        staffOnline[userID] = name
        print("`4[STAFF DETECTED] "..name)
		notify("Staff detected: `^"..cleanName(name).." `4(Script Paused)", "`4")
		LogToConsole("`4Staff detected: `^"..cleanName(name).." `4(Script Paused)")

        if safetyMode == "leave" and not exiting then
            exiting = true
            print("`4AUTO LEAVE (STAFF)")
            SendPacket(3, "action|quit_to_exit")
        end
    end
end)

